{
  "name": "@nocobase/cli",
  "version": "2.1.0-alpha.16",
  "description": "NocoBase CLI based on oclif",
  "license": "Apache-2.0",
  "main": "lib/index.js",
  "bin": {
    "nocobase": "./bin/run.js"
  },
  "files": [
    "bin",
    "lib"
  ],
  "dependencies": {
    "@oclif/core": "^4.5.6",
    "@oclif/plugin-help": "^6.2.44",
    "@oclif/plugin-plugins": "^5.4.61"
  },
  "oclif": {
    "bin": "nocobase",
    "dirname": "nocobase",
    "commands": "./lib/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {
      "hello": {
        "description": "Say hello to the world and others"
      }
    }
  }
}
