{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.nocobase.com/light-extension/client-app-entry-v1.schema.json",
  "title": "NocoBase client app entry.json v1",
  "description": "Canonical descriptor for one NocoBase light extension client application Entry.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "key"],
  "properties": {
    "schemaVersion": {
      "const": 1,
      "description": "Descriptor contract version."
    },
    "key": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$",
      "description": "Stable technical identity within one light extension repository."
    },
    "title": {
      "type": "string",
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"
    },
    "icon": {
      "type": "string",
      "maxLength": 120
    },
    "tags": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string"
      }
    },
    "sort": {
      "type": "integer"
    },
    "entry": {
      "type": "string",
      "default": "index.html",
      "description": "POSIX path to the HTML entry file, relative to the uploaded package root.",
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*[?#\\u0000])(?!(?:[A-Za-z][A-Za-z0-9+.-]*:|//))(?:[^/]+/)*[^/]+\\.[hH][tT][mM][lL]?$"
    }
  },
  "examples": [
    {
      "schemaVersion": 1,
      "key": "customer-console",
      "title": "Customer Console",
      "entry": "dist/application.html"
    }
  ]
}
