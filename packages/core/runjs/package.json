{
  "name": "@nocobase/runjs",
  "version": "2.2.0-beta.15",
  "main": "lib/index.js",
  "types": "./lib/index.d.ts",
  "typesVersions": {
    "*": {
      "compiler/portable": [
        "./lib/compiler/portable.d.ts"
      ]
    }
  },
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    },
    "./compiler": {
      "types": "./lib/compiler/index.d.ts",
      "import": "./lib/compiler/index.js",
      "require": "./lib/compiler/index.js"
    },
    "./compiler/portable": {
      "types": "./lib/compiler/portable.d.ts",
      "import": "./lib/compiler/portable.js",
      "require": "./lib/compiler/portable.js"
    },
    "./client-v2": {
      "types": "./lib/client-v2/index.d.ts",
      "import": "./lib/client-v2/index.js",
      "require": "./lib/client-v2/index.js"
    },
    "./settings": {
      "types": "./lib/settings/index.d.ts",
      "import": "./lib/settings/index.js",
      "require": "./lib/settings/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.25",
    "esbuild": "~0.27.0",
    "typescript": "5.1.3"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.6.1",
    "@formulajs/formulajs": "^4.4.9",
    "@types/lodash": "^4.17.24",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "antd": "^5.24.2",
    "dayjs": "^1.11.13",
    "lodash": "^4.17.21",
    "mathjs": "^15.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "scripts": {
    "generate": "yarn generate:completion-catalogs && yarn generate:dom-type-bridge && yarn generate:type-packs",
    "generate:check": "yarn generate:completion-catalogs --check && yarn generate:dom-type-bridge --check && yarn generate:type-packs --check",
    "generate:completion-catalogs": "tsx scripts/generate-completion-catalogs.ts",
    "generate:dom-type-bridge": "tsx scripts/generate-dom-type-only-bridge.ts",
    "generate:type-packs": "tsx scripts/generate-type-packs.ts"
  }
}
