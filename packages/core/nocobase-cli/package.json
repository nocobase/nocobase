  "devDependencies": {
    "@types/node": "^18.19.130",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nocobase/nocobase.git",
    "directory": "packages/core/nocobase-cli"
