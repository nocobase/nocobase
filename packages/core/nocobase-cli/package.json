          },
          "workflows": {
            "description": "Manage workflows and workflow revisions.",
            "subtopics": {}
          }
        }
      },
      "auth": {
        "description": "Manage local auth profiles and authentication helpers.",
        "subtopics": {
          "token": {
            "description": "Manage token-based auth profiles."
          }
        }
      }
    }
