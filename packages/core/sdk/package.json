      "types": "./lib/client/index.d.ts",
      "import": "./lib/client/index.js",
      "require": "./lib/client/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "qs": "^6.10.1"
  },
  "devDependencies": {
    "@nocobase/utils": "2.x",
    "axios-mock-adapter": "^1.20.0"
  },
  "gitHead": "d0b4efe4be55f8c79a98a331d99d9f8cf99021a1"
}
