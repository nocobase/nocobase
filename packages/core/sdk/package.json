{
  "name": "@nocobase/sdk",
  "version": "2.2.0-beta.15",
  "license": "Apache-2.0",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "typesVersions": {
    "*": {
      "client": [
        "lib/client/index.d.ts"
      ]
    }
  },
  "exports": {
