{
  "name": "@nocobase/plugin-light-extension",
  "displayName": "Light extensions",
  "displayName.zh-CN": "轻插件",
  "description": "Organize and reuse multi-file RunJS entries from light extension repositories.",
  "description.zh-CN": "组织并复用轻插件仓库中的多文件 RunJS Entry。",
  "version": "2.2.0-beta.11",
  "license": "Apache-2.0",
  "main": "./dist/server/index.js",
  "exports": {
    ".": {
      "types": "./server.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.js"
    },
    "./client": {
      "types": "./client.d.ts",
      "import": "./client.js",
      "require": "./client.js"
    },
    "./client-v2": {
      "types": "./client-v2.d.ts",
      "import": "./client-v2.js",
      "require": "./client-v2.js"
    },
    "./server": {
      "types": "./server.d.ts",
      "import": "./server.js",
      "require": "./server.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "homepage": "https://docs.nocobase.com",
  "homepage.zh-CN": "https://docs-cn.nocobase.com",
  "keywords": [
    "Developer tools"
  ],
  "dependencies": {
    "@nocobase/light-extension-sdk": "2.2.0-beta.13",
    "esbuild-wasm": "~0.27.0",
    "jszip": "^3.10.1",
    "mime-types": "^3.0.1",
    "parse5": "^7.1.2",
    "typescript": "^5.x",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@formily/core": "2.x",
    "@formily/react": "2.x",
    "@types/mime-types": "^3.0.1",
    "@types/yauzl": "^2.10.3",
    "dayjs": "^1.11.10",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.11.2"
  },
  "peerDependencies": {
    "@ant-design/icons": "5.x",
    "@nocobase/acl": "2.x",
    "@nocobase/actions": "2.x",
    "@nocobase/client-v2": "2.x",
    "@nocobase/database": "2.x",
    "@nocobase/flow-engine": "2.x",
    "@nocobase/plugin-file-manager": "2.x",
    "@nocobase/plugin-vsc-file": "2.x",
    "@nocobase/resourcer": "2.x",
    "@nocobase/runjs": "2.x",
    "@nocobase/server": "2.x",
    "@nocobase/test": "2.x",
    "@nocobase/utils": "2.x",
    "antd": "5.x",
    "react": "^18.2.0",
    "react-i18next": "^11.15.1"
  }
}
