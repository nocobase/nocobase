{
  "name": "@nocobase/plugin-vsc-file",
  "version": "2.2.0-beta.15",
  "main": "dist/server/index.js",
  "exports": {
    ".": {
      "types": "./server.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.js"
    },
    "./client": {
      "types": "./client.d.ts",
      "import": "./client.js",
      "require": "./client.js"
    },
    "./client-v2": {
      "types": "./client-v2.d.ts",
      "import": "./client-v2.js",
      "require": "./client-v2.js"
    },
    "./server": {
      "types": "./server.d.ts",
      "import": "./server.js",
      "require": "./server.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.6.1",
    "antd": "^5.24.2",
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "peerDependencies": {
    "@nocobase/actions": "2.x",
    "@nocobase/client": "2.x",
    "@nocobase/client-v2": "2.x",
    "@nocobase/database": "2.x",
    "@nocobase/flow-engine": "2.x",
    "@nocobase/plugin-environment-variables": "2.x",
    "@nocobase/resourcer": "2.x",
    "@nocobase/runjs": "2.x",
    "@nocobase/server": "2.x",
    "@nocobase/test": "2.x",
    "@nocobase/utils": "2.x"
  }
}
