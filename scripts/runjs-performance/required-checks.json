{
  "version": 1,
  "repository": "nocobase/nocobase",
  "checks": [
    {
      "id": "frontend",
      "type": "native-actions",
      "app": {
        "id": 15368,
        "slug": "github-actions",
        "name": "GitHub Actions",
        "owner": "github"
      },
      "sourceRepository": "nocobase/nocobase",
      "workflow": {
        "id": 59623513,
        "name": "NocoBase frontEnd test",
        "path": ".github/workflows/nocobase-test-frontend.yml",
        "event": "pull_request"
      },
      "jobs": [
        { "name": "install-deps (22)" },
        { "name": "frontend-test (22, 1)" },
        { "name": "frontend-test (22, 2)" },
        { "name": "frontend-test (22, 3)" },
        { "name": "frontend-test (22, 4)" }
      ]
    },
    {
      "id": "windows",
      "type": "native-actions",
      "app": {
        "id": 15368,
        "slug": "github-actions",
        "name": "GitHub Actions",
        "owner": "github"
      },
      "sourceRepository": "nocobase/nocobase",
      "workflow": {
        "id": 98560818,
        "name": "Test on Windows",
        "path": ".github/workflows/nocobase-test-windows.yml",
        "event": "pull_request"
      },
      "jobs": [{ "name": "build" }]
    },
    {
      "id": "backend",
      "type": "external-check-run",
      "name": "Backend test",
      "app": {
        "id": 979192,
        "slug": "nocobase",
        "name": "nocobase",
        "owner": "nocobase"
      },
      "sourceRepository": "chenos/nocobase-ci",
      "workflow": {
        "id": 156411441,
        "name": "NocoBase backend test",
        "path": ".github/workflows/oss-backend-test.yml",
        "event": "workflow_dispatch"
      },
      "jobs": [
        { "name": "backend-test (22, sqlite, localhost, false)" },
        { "name": "backend-test (22, sqlite, localhost, true)" },
        { "name": "backend-test (22, mysql, mysql, 3306, root, default-mysql-client, false)" },
        { "name": "backend-test (22, mysql, mysql, 3306, root, default-mysql-client, true)" },
        { "name": "backend-test (22, mariadb, mariadb, 3306, root, mariadb-client, false)" },
        { "name": "backend-test (22, mariadb, mariadb, 3306, root, mariadb-client, true)" },
        { "name": "backend-test (22, postgres, postgres, 5432, postgres, public, public, postgresql-client, false)" },
        { "name": "backend-test (22, postgres, postgres, 5432, postgres, public, public, postgresql-client, true)" },
        { "name": "backend-test (22, postgres, postgres, 5432, postgres, nocobase, public, postgresql-client, false)" },
        { "name": "backend-test (22, postgres, postgres, 5432, postgres, nocobase, public, postgresql-client, true)" },
        {
          "name": "backend-test (22, postgres, postgres, 5432, postgres, public, user_schema, postgresql-client, false)"
        },
        {
          "name": "backend-test (22, postgres, postgres, 5432, postgres, public, user_schema, postgresql-client, true)"
        },
        {
          "pattern": "^backend-test \\(22, postgres, postgres, 5432, postgres, nocobase, user_schema, postgresql-client, f(?:alse\\)|\\.\\.\\.)$"
        },
        {
          "pattern": "^backend-test \\(22, postgres, postgres, 5432, postgres, nocobase, user_schema, postgresql-client, t(?:rue\\)|\\.\\.\\.)$"
        },
        {
          "pattern": "^backend-test \\(22, true, postgres, postgres, 5432, postgres, redis://redis:6379/2, public, public,(?:.*|\\.\\.\\.)$"
        }
      ]
    },
    {
      "id": "build-pro-image",
      "type": "external-check-run",
      "name": "Build pro image",
      "app": {
        "id": 979192,
        "slug": "nocobase",
        "name": "nocobase",
        "owner": "nocobase"
      },
      "sourceRepository": "2013xile/nocobase-ci",
      "workflow": {
        "id": 129735148,
        "name": "Build pro image",
        "path": ".github/workflows/build-pro-image.yml",
        "event": "workflow_dispatch"
      },
      "jobs": [
        { "name": "get-plugins / get-plugins" },
        { "name": "prepare-meta" },
        { "name": "check-docs" },
        { "name": "build-app" },
        { "name": "build-docs" },
        { "name": "check-and-build-with-types" },
        { "name": "assemble-image" },
        { "name": "update-status" },
        { "name": "dispatch-e2e" }
      ]
    },
    {
      "id": "cla",
      "type": "status-context",
      "context": "license/cla",
      "creator": "zhouyanliang",
      "targetUrlPattern": "^https://cla-assistant\\.io/nocobase/nocobase\\?pullRequest="
    }
  ]
}
