# ============================================================
# NocoBase Docker 部署环境变量配置
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 修改 .env 中的敏感信息（APP_KEY、数据库密码等）
# 3. 不要将 .env 文件提交到 Git 仓库

# ============================================================
# 应用配置
# ============================================================
APP_ENV=production
APP_PORT=13000
APP_KEY=your-secret-key-change-this-in-production
ENCRYPTION_FIELD_KEY=your-encryption-key-change-this

# ============================================================
# 数据库配置 (PostgreSQL)
# ============================================================
DB_DIALECT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nocobase
DB_USER=nocobase
DB_PASSWORD=nocobase_db_password_change_this
DB_POSTGRES_PORT=5432

# ============================================================
# Redis 配置
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=nocobase_redis_password_change_this

# ============================================================
# MinIO 对象存储配置
# ============================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_password_change_this
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================
# 应用访问配置
# ============================================================
APP_PORT=13000

# ============================================================
# 日志配置
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================
# 备份配置
# ============================================================
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *
